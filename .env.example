# ============================================================
# BINANCE FUTURES LAB - Environment Variables
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositorio!
# ============================================================

# --- Modo de operacao ---
# paper = simulacao local sem enviar ordens reais
# testnet = envia ordens para Binance Futures Testnet
# live = PRODUCAO - cuidado!
APP_MODE=paper

# --- Binance API (Testnet) ---
# Obtenha em: https://testnet.binancefuture.com
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# --- URLs Base ---
# Testnet REST
BASE_URL=https://demo-fapi.binance.com
# Testnet WebSocket
WS_BASE_URL=wss://fstream.binancefuture.com

# --- Simbolos monitorados (separados por virgula) ---
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# --- Intervalo de candles ---
# 1m, 3m, 5m, 15m, 1h, 4h, 1d
INTERVAL=5m

# --- Gestao de Risco ---
# Percentual do saldo arriscado por trade (0.01 = 1%)
RISK_PER_TRADE=0.01
# Drawdown maximo diario permitido (0.05 = 5%)
MAX_DAILY_DRAWDOWN=0.05
# Alavancagem maxima
MAX_LEVERAGE=5

# --- Paper Trading ---
# Saldo simulado inicial em USDT
PAPER_BALANCE=10000.0

# --- Web / Painel ---
WEB_HOST=0.0.0.0
WEB_PORT=8000

# --- Logs ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
